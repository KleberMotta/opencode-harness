{
  "name": "juninho-harness",
  "version": "0.1.0",
  "private": true,
  "description": "CLI utilitário para o harness Juninho (.opencode) — edita config, ativa planos e inspeciona estado sem abrir sessão",
  "type": "module",
  "scripts": {
    "prepare": "bun .opencode/cli/sync-config.ts",
    "sync": "bun .opencode/cli/sync-config.ts",
    "model:list": "bun .opencode/cli/model-list.ts",
    "model:set": "bun .opencode/cli/model-set.ts",
    "config:show": "bun .opencode/cli/config-show.ts",
    "config:validate": "bun .opencode/cli/config-validate.ts",
    "toggle": "bun .opencode/cli/toggle.ts",
    "plan:active": "bun .opencode/cli/plan-active.ts",
    "plan:activate": "bun .opencode/cli/plan-activate.ts",
    "plan:clear": "bun .opencode/cli/plan-clear.ts",
    "state:show": "bun .opencode/cli/state-show.ts",
    "state:clear-task": "bun .opencode/cli/state-clear-task.ts",
    "skills:list": "bun .opencode/cli/skills-list.ts",
    "agents:list": "bun .opencode/cli/agents-list.ts",
    "graphify:build": "bun .opencode/cli/graphify-build.ts",
    "graphify:refresh": "bun .opencode/cli/graphify-build.ts --incremental",
    "graphify:status": "bun .opencode/cli/graphify-status.ts",
    "eval": "node .opencode/evals/run-layer.mjs all",
    "eval:structural": "node .opencode/evals/run-layer.mjs structural",
    "eval:hooks": "node .opencode/evals/run-layer.mjs hooks",
    "eval:context": "node .opencode/evals/run-layer.mjs context",
    "eval:state": "node .opencode/evals/run-layer.mjs state",
    "eval:behavioral": "node .opencode/evals/run-behavioral.mjs smoke",
    "eval:behavioral:smoke": "node .opencode/evals/run-behavioral.mjs smoke",
    "eval:behavioral:impact:carl": "node .opencode/evals/run-behavioral.mjs impact carl",
    "eval:behavioral:impact:runtime": "node .opencode/evals/run-behavioral.mjs impact runtime",
    "eval:behavioral:impact:workflow": "node .opencode/evals/run-behavioral.mjs impact workflow",
    "eval:behavioral:impact:tools": "node .opencode/evals/run-behavioral.mjs impact tools",
    "eval:behavioral:context-suite": "node .opencode/evals/run-behavioral.mjs context",
    "eval:behavioral:workflow-suite": "node .opencode/evals/run-behavioral.mjs workflow",
    "eval:behavioral:tools-suite": "node .opencode/evals/run-behavioral.mjs tools",
    "eval:behavioral:full": "node .opencode/evals/run-behavioral.mjs full",
    "eval:behavioral:context": "JUNINHO_EVAL_OFFSET=0 JUNINHO_EVAL_LIMIT=3 bun .opencode/evals/lib/opencode-behavioral-runner.ts .opencode/evals/behavioral.xml .opencode/evals/reports/behavioral-context-report.md",
    "eval:behavioral:tools": "JUNINHO_EVAL_OFFSET=3 JUNINHO_EVAL_LIMIT=3 bun .opencode/evals/lib/opencode-behavioral-runner.ts .opencode/evals/behavioral.xml .opencode/evals/reports/behavioral-tools-report.md",
    "eval:behavioral:commit": "JUNINHO_EVAL_OFFSET=6 JUNINHO_EVAL_LIMIT=2 bun .opencode/evals/lib/opencode-behavioral-runner.ts .opencode/evals/behavioral.xml .opencode/evals/reports/behavioral-commit-report.md",
    "eval:behavioral:skill-effect": "JUNINHO_EVAL_OFFSET=8 JUNINHO_EVAL_LIMIT=1 bun .opencode/evals/lib/opencode-behavioral-runner.ts .opencode/evals/behavioral.xml .opencode/evals/reports/behavioral-skill-effect-report.md",
    "eval:behavioral:subagent-context": "JUNINHO_EVAL_OFFSET=9 JUNINHO_EVAL_LIMIT=1 bun .opencode/evals/lib/opencode-behavioral-runner.ts .opencode/evals/behavioral.xml .opencode/evals/reports/behavioral-subagent-context-report.md",
    "eval:behavioral:mixed-domain-context": "JUNINHO_EVAL_OFFSET=10 JUNINHO_EVAL_LIMIT=1 bun .opencode/evals/lib/opencode-behavioral-runner.ts .opencode/evals/behavioral.xml .opencode/evals/reports/behavioral-mixed-domain-context-report.md",
    "eval:behavioral:dual-domain-context": "JUNINHO_EVAL_OFFSET=11 JUNINHO_EVAL_LIMIT=1 bun .opencode/evals/lib/opencode-behavioral-runner.ts .opencode/evals/behavioral.xml .opencode/evals/reports/behavioral-dual-domain-context-report.md",
    "eval:behavioral:cashout-balance-context": "JUNINHO_EVAL_OFFSET=12 JUNINHO_EVAL_LIMIT=1 bun .opencode/evals/lib/opencode-behavioral-runner.ts .opencode/evals/behavioral.xml .opencode/evals/reports/behavioral-cashout-balance-context-report.md",
    "eval:behavioral:implement-loop": "JUNINHO_EVAL_OFFSET=13 JUNINHO_EVAL_LIMIT=1 bun .opencode/evals/lib/opencode-behavioral-runner.ts .opencode/evals/behavioral.xml .opencode/evals/reports/behavioral-implement-loop-report.md",
    "eval:behavioral:check-loop": "JUNINHO_EVAL_OFFSET=14 JUNINHO_EVAL_LIMIT=1 bun .opencode/evals/lib/opencode-behavioral-runner.ts .opencode/evals/behavioral.xml .opencode/evals/reports/behavioral-check-loop-report.md",
    "eval:behavioral:unify-loop": "JUNINHO_EVAL_OFFSET=15 JUNINHO_EVAL_LIMIT=1 bun .opencode/evals/lib/opencode-behavioral-runner.ts .opencode/evals/behavioral.xml .opencode/evals/reports/behavioral-unify-loop-report.md",
    "eval:behavioral:checker-startup": "JUNINHO_EVAL_OFFSET=16 JUNINHO_EVAL_LIMIT=1 bun .opencode/evals/lib/opencode-behavioral-runner.ts .opencode/evals/behavioral.xml .opencode/evals/reports/behavioral-checker-startup-report.md",
    "eval:behavioral:planner-startup": "JUNINHO_EVAL_OFFSET=17 JUNINHO_EVAL_LIMIT=1 bun .opencode/evals/lib/opencode-behavioral-runner.ts .opencode/evals/behavioral.xml .opencode/evals/reports/behavioral-planner-startup-report.md",
    "eval:behavioral:spec-startup": "JUNINHO_EVAL_OFFSET=18 JUNINHO_EVAL_LIMIT=1 bun .opencode/evals/lib/opencode-behavioral-runner.ts .opencode/evals/behavioral.xml .opencode/evals/reports/behavioral-spec-startup-report.md"
  },
  "dependencies": {
    "@opencode-ai/plugin": "1.4.9"
  }
}
