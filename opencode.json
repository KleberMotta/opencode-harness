{
  "mcp": {
    "context7": {
      "type": "local",
      "command": ["npx", "-y", "@upstash/context7-mcp@latest"]
    },
    "context-mode": {
      "type": "local",
      "command": ["context-mode"]
    },
    "exa": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp",
      "enabled": true
    }
  },
  "agent": {
    "j.planner": {
      "model": "github-copilot/claude-opus-4.6",
      "permission": {
        "write": "allow",
        "bash": "allow",
        "task": {
          "*": "deny",
          "j.explore": "allow",
          "j.librarian": "allow",
          "j.plan-reviewer": "allow"
        },
        "edit": "deny",
        "question": "allow"
      }
    },
    "j.plan-reviewer": {
      "model": "github-copilot/claude-opus-4.6",
      "permission": {
        "task": "deny",
        "bash": "deny",
        "write": "deny",
        "edit": "deny",
        "question": "deny"
      }
    },
    "j.spec-writer": {
      "model": "github-copilot/claude-opus-4.6",
      "permission": {
        "bash": "deny",
        "write": "allow",
        "edit": "deny",
        "task": {
          "*": "deny",
          "j.explore": "allow"
        },
        "question": "allow"
      }
    },
    "j.implementer": {
      "model": "github-copilot/claude-sonnet-4.6",
      "permission": {
        "bash": "allow",
        "write": "allow",
        "edit": "allow",
        "task": {
          "*": "deny",
          "j.implementer": "allow",
          "j.validator": "allow"
        },
        "question": "deny"
      }
    },
    "j.validator": {
      "model": "github-copilot/claude-opus-4.6",
      "permission": {
        "bash": "allow",
        "write": "allow",
        "edit": "allow",
        "task": "deny",
        "question": "deny"
      }
    },
    "j.reviewer": {
      "model": "github-copilot/claude-opus-4.6",
      "permission": {
        "bash": "deny",
        "write": "deny",
        "edit": "deny",
        "task": "deny",
        "question": "deny"
      }
    },
    "j.checker": {
      "model": "github-copilot/claude-opus-4.6",
      "permission": {
        "bash": "allow",
        "write": "allow",
        "edit": "allow",
        "task": {
          "*": "deny",
          "j.reviewer": "allow"
        },
        "question": "deny"
      }
    },
    "j.unify": {
      "model": "github-copilot/claude-opus-4.6",
      "permission": {
        "bash": "allow",
        "write": "allow",
        "edit": "allow",
        "task": "deny",
        "question": "deny"
      }
    },
    "j.explore": {
      "model": "github-copilot/claude-haiku-4.5",
      "permission": {
        "bash": "deny",
        "write": "deny",
        "edit": "deny",
        "task": "deny",
        "question": "deny"
      }
    },
    "j.librarian": {
      "model": "github-copilot/claude-haiku-4.5",
      "permission": {
        "bash": "deny",
        "write": "deny",
        "edit": "deny",
        "task": "deny",
        "question": "deny"
      }
    },
    "j.plan": {
      "model": "github-copilot/claude-opus-4.6",
      "permission": {
        "task": {
          "*": "deny",
          "j.planner": "allow"
        },
        "bash": "deny",
        "write": "deny",
        "edit": "deny",
        "question": "deny"
      }
    },
    "j.spec": {
      "model": "github-copilot/claude-opus-4.6",
      "permission": {
        "task": {
          "*": "deny",
          "j.spec-writer": "allow"
        },
        "bash": "deny",
        "write": "deny",
        "edit": "deny",
        "question": "deny"
      }
    }
  },
  "plugin": ["context-mode"],
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "github-copilot": {
      "models": {
        "gpt-5.4-OK": {
          "limit": {
            "context": 400000,
            "output": 32000
          }
        }
      }
    }
  },
  "permission": {
    "*": "allow",
    "doom_loop": "deny",
    "external_directory": {
      "*": "deny",
      "~/repos/**": "allow",
      "~/.config/opencode/**": "allow"
    },
    "read": {
      "*": "allow",
      "*.env": "allow",
      "*.env.*": "allow",
      "*.env.example": "allow"
    }
  }
}
